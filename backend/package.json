{
  "name": "backend",
  "version": "1.0.0",
  "description": "GOAR/NOAR Green Open Access Management System Backend",
  "main": "dist/server.js",
  "scripts": {
    "predev": "npm run prisma:generate",
    "dev": "nodemon --exec ts-node src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "prisma:generate": "prisma generate",
    "prisma:seed": "ts-node prisma/seed.ts",
    "postinstall": "npm run prisma:generate"
  },
  "dependencies": {
    "@prisma/client": "^6.4.0",
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^8.0.10",
    "twilio": "^6.0.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/multer": "^1.4.12",
    "@types/node": "^20.11.24",
    "@types/nodemailer": "^8.0.0",
    "nodemon": "^3.1.0",
    "prisma": "^6.4.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
