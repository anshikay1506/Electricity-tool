generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String             @id @default(uuid())
  email             String             @unique
  passwordHash      String
  name              String
  role              Role
  state             String
  utilityType       String?
  status            String             @default("PENDING")
  createdAt         DateTime           @default(now())
  phoneNumber       String?
  bids              Bid[]              @relation("UserBids")
  consumerProfile   ConsumerProfile?
  consumerContracts Contract[]         @relation("ConsumerContracts")
  supplierContracts Contract[]         @relation("SupplierContracts")
  documents         Document[]
  payments          Payment[]
  supplierDocuments SupplierDocument[]
  supplierProfile   SupplierProfile?
}

model ConsumerProfile {
  id          String  @id @default(uuid())
  userId      String  @unique
  drawalPoint String
  oaStatus    String  @default("INACTIVE")
  phoneNumber String?
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SupplierProfile {
  id             String  @id @default(uuid())
  userId         String  @unique
  injectionPoint String
  renewableType  String
  phoneNumber    String?
  user           User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Bid {
  id         String   @id @default(uuid())
  userId     String
  mw         Float
  price      Float
  marketType String
  timeBlock  String
  status     String   @default("PENDING")
  createdAt  DateTime @default(now())
  user       User     @relation("UserBids", fields: [userId], references: [id], onDelete: Cascade)
}

model Application {
  id                  String    @id @default(uuid())
  consumerId          String
  supplierId          String
  mw                  Float
  type                String    @default("Green OA")
  annexureCStatus     String    @default("PENDING")
  annexureDStatus     String    @default("PENDING")
  annexureEStatus     String    @default("PENDING")
  approvalStatus      String    @default("ADMIN_PENDING")
  lossPercentage      Float     @default(3.5)
  injectionPoint      String
  drawalPoint         String
  durationDays        Int       @default(365)
  ppaUrl              String?
  oaAppUrl            String?
  bgUrl               String?
  authLetterUrl       String?
  createdAt           DateTime  @default(now())
  adminApproved       Boolean   @default(false)
  adminApprovedAt     DateTime?
  applicantName       String?
  consumerName        String?
  contactEmail        String?
  contactMobile       String?
  contactPerson       String?
  contractGenerated   Boolean   @default(false)
  contractGeneratedAt DateTime?
  contractId          String?
  contractUrl         String?
  discom              String?
  discomConsumerNo    String?
  documentChecklist   Json?
  entityType          String?
  legalIdentifier     String?
  proposedStartDate   String?
  registeredAddress   String?
  rejectionReason     String?
  renewableType       String?
  requestedPrice      Float?
  scheduleType        String?
  state               String?
  supplierApproved    Boolean   @default(false)
  supplierApprovedAt  DateTime?
  timeBlocks          String?
  voltageLevel        String?
  contract            Contract?
  documents Document[]
}

model Contract {
  id               String      @id
  applicationId    String      @unique
  consumerId       String
  supplierId       String
  contractNumber   String      @unique
  startDate        DateTime
  endDate          DateTime
  mw               Int
  pricePerUnit     Float
  totalValue       Float
  status           String
  signedByConsumer Boolean     @default(false)
  signedBySupplier Boolean     @default(false)
  signedAt         DateTime?
  pdfUrl           String?
  createdAt        DateTime    @default(now())
  application      Application @relation(fields: [applicationId], references: [id])
  consumer         User        @relation("ConsumerContracts", fields: [consumerId], references: [id])
  supplier         User        @relation("SupplierContracts", fields: [supplierId], references: [id])
}

model SupplierDocument {
  id           String    @id
  supplierId   String
  name         String
  documentType String
  description  String?
  filePath     String
  fileSize     Int
  mimeType     String
  status       String    @default("PENDING")
  verifiedAt   DateTime?
  verifiedBy   String?
  uploadedAt   DateTime  @default(now())
  supplier     User      @relation(fields: [supplierId], references: [id])
}

model Schedule {
  id            String   @id @default(uuid())
  applicationId String
  supplierId    String
  consumerId    String
  mw            Float
  timeBlock     String
  gridStatus    String   @default("SCHEDULED")
  createdAt     DateTime @default(now())
}

model Document {
  id        String   @id @default(uuid())
  title     String
  category  String
  fileUrl   String
  status    String   @default("PENDING")
  userId    String
  applicationId String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  application   Application? @relation(fields: [applicationId], references: [id])
}

model Payment {
  id        String   @id @default(uuid())
  userId    String
  amount    Float
  currency  String   @default("INR")
  status    String   @default("PENDING")
  reference String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model MarketPrice {
  id     String @id @default(uuid())
  market String @unique
  price  Float
  change String
}

enum Role {
  ADMIN
  SUPPLIER
  CONSUMER
  TRADER
}
