generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String             @id
  email             String             @unique
  name              String
  role              String
  k_number          String?            @unique
  connection_type   String?
  passwordHash      String
  phoneNumber       String?            @unique
  status            String?            @default("PENDING")
  consumerProfile   ConsumerProfile?
  consumerContracts Contract[]         @relation("ConsumerContracts")
  supplierContracts Contract[]         @relation("SupplierContracts")
  documents         Document[]
  payments          Payment[]
  supplierDocuments SupplierDocument[]
  supplierProfile   SupplierProfile?

  @@map("User")
}

model ConsumerProfile {
  id          String  @id @default(uuid())
  userId      String  @unique
  drawalPoint String
  phoneNumber String?
  k_number    String? @unique
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("ConsumerProfile")
}

model SupplierProfile {
  id             String  @id
  userId         String  @unique
  injectionPoint String
  renewableType  String
  phoneNumber    String?
  contactPerson  String?
  registrationNo String?
  totalCapacity  Float?
  user           User    @relation(fields: [userId], references: [id])

  @@map("SupplierProfile")
}

model Bid {
  id           String   @id @default(cuid())
  consumerId   String
  consumerName String?
  mw           Float
  price        Float
  duration     Int
  drawalPoint  String?
  scheduleType  String?
  message      String?
  status       String   @default("ACTIVE")
  validityDays Int      @default(30)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  offers       BidOffer[]

  @@map("Bid")
}

model BidOffer {
  id           String   @id @default(cuid())
  bidId        String
  supplierId   String
  supplierName String
  offeredPrice Float
  offeredMw    Float
  message      String?
  status       String   @default("PENDING")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  bid          Bid      @relation(fields: [bidId], references: [id], onDelete: Cascade)

  @@map("BidOffer")
}

model Application {
  id                  String    @id @default(uuid())
  consumerId          String
  supplierId          String
  mw                  Float
  type                String    @default("Green OA")
  annexureCStatus     String    @default("PENDING")
  annexureDStatus     String    @default("PENDING")
  annexureEStatus     String    @default("PENDING")
  approvalStatus      String    @default("ADMIN_PENDING")
  lossPercentage      Float     @default(3.5)
  injectionPoint      String
  drawalPoint         String
  durationDays        Int       @default(365)
  ppaUrl              String?
  oaAppUrl            String?
  bgUrl               String?
  authLetterUrl       String?
  createdAt           DateTime  @default(now())
  adminApproved       Boolean   @default(false)
  adminApprovedAt     DateTime?
  applicantName       String?
  consumerName        String?
  contactEmail        String?
  contactMobile       String?
  contactPerson       String?
  contractGenerated   Boolean   @default(false)
  contractGeneratedAt DateTime?
  contractId          String?
  contractUrl         String?
  discom              String?
  discomConsumerNo    String?
  documentChecklist   Json?
  entityType          String?
  legalIdentifier     String?
  proposedStartDate   String?
  registeredAddress   String?
  rejectionReason     String?
  renewableType       String?
  requestedPrice      Float?
  scheduleType        String?
  state               String?
  supplierApproved    Boolean   @default(false)
  supplierApprovedAt  DateTime?
  timeBlocks          String?
  voltageLevel        String?
  contract            Contract?
}

model Plant {
  id             String  @id @default(cuid())
  supplierId     String
  supplierName   String
  name           String
  type           String
  total          Float
  available      Float
  price          Float
  injectionPoint String
  status         String
  state          String?

  @@map("Plant")
}

model Contract {
  id               String      @id
  applicationId    String      @unique
  consumerId       String
  supplierId       String
  contractNumber   String      @unique
  startDate        DateTime
  endDate          DateTime
  mw               Int
  pricePerUnit     Float
  totalValue       Float
  status           String
  signedByConsumer Boolean     @default(false)
  signedBySupplier Boolean     @default(false)
  signedAt         DateTime?
  pdfUrl           String?
  createdAt        DateTime    @default(now())
  application      Application @relation(fields: [applicationId], references: [id])
  consumer         User        @relation("ConsumerContracts", fields: [consumerId], references: [id])
  supplier         User        @relation("SupplierContracts", fields: [supplierId], references: [id])
}

model SupplierDocument {
  id           String    @id
  supplierId   String
  name         String
  documentType String
  description  String?
  filePath     String
  fileSize     Int
  mimeType     String
  status       String    @default("PENDING")
  verifiedAt   DateTime?
  verifiedBy   String?
  uploadedAt   DateTime  @default(now())
  supplier     User      @relation(fields: [supplierId], references: [id])

  @@map("SupplierDocument")
}

model Schedule {
  id            String   @id @default(uuid())
  applicationId String
  supplierId    String
  consumerId    String
  mw            Float
  timeBlock     String
  gridStatus    String   @default("SCHEDULED")
  createdAt     DateTime @default(now())

  @@map("Schedule")
}

model Document {
  id        String   @id @default(uuid())
  title     String
  category  String
  fileUrl   String
  status    String   @default("PENDING")
  userId    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("Document")
}

model Payment {
  id        String   @id @default(uuid())
  userId    String
  amount    Float
  currency  String   @default("INR")
  status    String   @default("PENDING")
  reference String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("Payment")
}

model MarketPrice {
  id     String @id @default(uuid())
  market String @unique
  price  Float
  change String

  @@map("MarketPrice")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model electricboard {
  k_number        String  @id
  mobile_number   String  @unique
  name            String
  connection_type String
  email           String?
  meter_type      String?
  area_type       String?
  connected_load  Float?
  demand_load     Float?
  address         String?
  discom          String?
}
