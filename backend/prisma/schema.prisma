datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id              String  @id
  email           String  @unique
  passwordHash    String
  name            String
  role            String
  phoneNumber     String? @unique
  k_number        String? @unique
  connection_type String?

  consumerProfile   ConsumerProfile?
  supplierProfile   SupplierProfile?
  bids              Bid[]
  consumerContracts Contract[]         @relation("ConsumerContracts")
  supplierContracts Contract[]         @relation("SupplierContracts")
  supplierDocuments SupplierDocument[]
  documents         Document[]
  payments          Payment[]

  @@map("User")
}


model ConsumerProfile {
  id          String  @id @default(uuid())
  userId      String  @unique
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  phoneNumber String?
  drawalPoint String
  k_number        String?  @unique

  @@map("ConsumerProfile")
}

model SupplierProfile {
  id             String  @id @default(uuid())
  userId         String  @unique
  user           User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  phoneNumber    String?
  injectionPoint String
  renewableType  String

  @@map("SupplierProfile")
}

model Bid {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  mw         Float
  price      Float
  marketType String
  timeBlock  String
  status     String   @default("PENDING")
  createdAt  DateTime @default(now())

  @@map("Bid")
}

model Application {
  id                String  @id @default(uuid())
  consumerId        String
  supplierId        String
  mw                Float
  type              String  @default("Green OA")
  applicantName     String?
  entityType        String?
  legalIdentifier   String?
  discomConsumerNo  String?
  registeredAddress String?
  state             String?
  discom            String?
  contactPerson     String?
  contactEmail      String?
  contactMobile     String?
  voltageLevel      String?
  renewableType     String?
  scheduleType      String?
  proposedStartDate String?
  timeBlocks        String?
  documentChecklist Json?
  annexureCStatus   String  @default("PENDING")
  annexureDStatus   String  @default("PENDING")
  annexureEStatus   String  @default("PENDING")
  approvalStatus    String  @default("ADMIN_PENDING")
  lossPercentage    Float   @default(3.5)
  injectionPoint    String
  drawalPoint       String
  durationDays      Int     @default(365)
  requestedPrice    Float?
  consumerName      String?

  adminApproved     Boolean @default(false)
  supplierApproved  Boolean @default(false)
  contractGenerated Boolean @default(false)

  adminApprovedAt     DateTime?
  supplierApprovedAt  DateTime?
  contractGeneratedAt DateTime?
  rejectionReason     String?
  contractId          String?
  contractUrl         String?

  ppaUrl        String?
  oaAppUrl      String?
  bgUrl         String?
  authLetterUrl String?
  createdAt     DateTime @default(now())

  contract Contract?
}

model Contract {
  id               String    @id
  applicationId    String    @unique
  consumerId       String
  supplierId       String
  contractNumber   String    @unique
  startDate        DateTime
  endDate          DateTime
  mw               Int
  pricePerUnit     Float
  totalValue       Float
  status           String
  signedByConsumer Boolean   @default(false)
  signedBySupplier Boolean   @default(false)
  signedAt         DateTime?
  pdfUrl           String?
  createdAt        DateTime  @default(now())

  application Application @relation(fields: [applicationId], references: [id])
  consumer    User        @relation("ConsumerContracts", fields: [consumerId], references: [id])
  supplier    User        @relation("SupplierContracts", fields: [supplierId], references: [id])
}

model SupplierDocument {
  id           String    @id
  supplierId   String
  name         String
  documentType String
  description  String?
  filePath     String
  fileSize     Int
  mimeType     String
  status       String    @default("PENDING")
  verifiedAt   DateTime?
  verifiedBy   String?
  uploadedAt   DateTime  @default(now())

  supplier User @relation(fields: [supplierId], references: [id])

  @@map("SupplierDocument")
}

model Schedule {
  id            String   @id @default(uuid())
  applicationId String
  supplierId    String
  consumerId    String
  mw            Float
  timeBlock     String
  gridStatus    String   @default("SCHEDULED")
  createdAt     DateTime @default(now())

  @@map("Schedule")
}

model Document {
  id        String   @id @default(uuid())
  title     String
  category  String
  fileUrl   String
  status    String   @default("PENDING")
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@map("Document")
}

model Payment {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount    Float
  currency  String   @default("INR")
  status    String   @default("PENDING")
  reference String?
  createdAt DateTime @default(now())

  @@map("Payment")
}

model MarketPrice {
  id     String @id @default(uuid())
  market String @unique
  price  Float
  change String

  @@map("MarketPrice")
}

model electricboard {
  k_number        String  @id @map("k_number")
  mobile_number   String  @unique @map("mobile_number")
  name            String
  connection_type String  @map("connection_type")
  email           String?

  @@map("electricboard")
}
